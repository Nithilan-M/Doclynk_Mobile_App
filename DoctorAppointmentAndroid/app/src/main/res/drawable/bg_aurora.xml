<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#EAF6FF"
                android:startColor="#F6FBFF"
                android:type="linear" />
        </shape>
    </item>
    <item android:top="-120dp" android:left="-80dp">
        <shape android:shape="oval">
            <size android:width="320dp" android:height="320dp" />
            <solid android:color="#803AC7FF" />
        </shape>
    </item>
    <item android:bottom="-140dp" android:right="-60dp">
        <shape android:shape="oval">
            <size android:width="360dp" android:height="360dp" />
            <solid android:color="#80A4FFB5" />
        </shape>
    </item>
</layer-list>
